# Токен Telegram-бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Логин и пароль для входа в админ-панель
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your_secure_password_here
ADMIN1_LOGIN=Admin1
ADMIN1_PASSWORD=Admin6611
GUEST1_LOGIN=Guest1
GUEST2_LOGIN=Guest2
GUEST3_LOGIN=Guest3
GUEST_PASSWORD=Guest6611

# Секретный ключ Flask (сгенерируй свой: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_this_to_random_string

# Публичный адрес сайта для webhook
WEBHOOK_BASE_URL=https://your-domain.up.railway.app

# Секрет для проверки webhook от Telegram
WEBHOOK_SECRET=change_this_to_long_random_string

# Порт приложения
PORT=8080

# Постоянная папка для базы и файлов.
# Для Railway удобно указать путь смонтированного Volume, например /app/data
APP_DATA_DIR=

# Необязательно: явный путь к SQLite-базе
DB_PATH=

# Необязательно: явный путь к папке загруженных файлов
UPLOAD_FOLDER=
