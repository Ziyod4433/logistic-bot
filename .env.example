# Токен Telegram-бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Логин и пароль для входа в админ-панель
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your_secure_password_here

# Секретный ключ Flask (сгенерируй свой: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_this_to_random_string

# Публичный адрес сайта для webhook
WEBHOOK_BASE_URL=https://your-domain.up.railway.app

# Секрет для проверки webhook от Telegram
WEBHOOK_SECRET=change_this_to_long_random_string

# Порт приложения
PORT=8080
